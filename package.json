{
  "name": "@inferagraph/sql",
  "version": "0.2.2",
  "type": "module",
  "description": "SQL datasource, vector embedding store, inferred-edge store, conversation store, and cache provider for InferaGraph (PostgreSQL with pgvector for vector stores; PostgreSQL/MySQL/SQLite/MSSQL for the rest)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inferagraph/sql.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "packageManager": "pnpm@10.33.2",
  "license": "MIT",
  "peerDependencies": {
    "@inferagraph/core": "^0.10.1"
  },
  "dependencies": {
    "knex": "^3.1.0"
  },
  "devDependencies": {
    "@inferagraph/core": "^0.10.1",
    "@vitest/coverage-v8": "^3.1.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
